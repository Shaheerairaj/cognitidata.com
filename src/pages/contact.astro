---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ContactForm from "../components/ContactForm.astro";
import ScrollReveal from "../components/ScrollReveal.tsx";
import { SITE } from "../config/site.mjs";
---

<Layout
  title={`Contact | ${SITE.title}`}
  description="Let's find what's slowing your business down and fix it. First call is free, no pitch deck, no pressure."
  canonicalURL={`${SITE.url}/contact`}
>
  <Header />
  <main id="main-content" role="main">
    <section class="px-6" style="padding-top: 96px; padding-bottom: 96px;">
      <div class="mx-auto" style="max-width: 540px;">
        <ScrollReveal client:idle>
          <p class="eyebrow mb-5">Get in touch</p>
          <h1
            style="font-size: clamp(44px, 5.5vw, 72px); line-height: 1.1; color: var(--color-text);"
          >
            Let's talk about your business
          </h1>
        </ScrollReveal>

        <ScrollReveal client:idle delay={0.1}>
          <p class="mt-6 mb-4" style="font-size: 22px; line-height: 1.65; color: var(--color-body);">
            First call is free, no pitch deck, no pressure.
          </p>
          <a
            href="mailto:shaheer@cognitidata.com"
            class="inline-block transition-opacity duration-200 hover:opacity-60"
            style="font-size: 15px; color: var(--color-muted);"
          >
            shaheer@cognitidata.com
          </a>
        </ScrollReveal>

        <ScrollReveal client:idle delay={0.2}>
          <div class="mt-12 pt-12 border-t" style="border-color: var(--color-border);">
            <ContactForm />
          </div>
        </ScrollReveal>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
