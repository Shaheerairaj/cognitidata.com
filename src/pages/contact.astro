---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ContactForm from "../components/ContactForm.astro";
import ScrollReveal from "../components/ScrollReveal.tsx";
import { Icon } from "astro-icon/components";
import { SITE } from "../config/site.mjs";
---

<Layout
  title={`Contact | ${SITE.title}`}
  description="Ready to build something? Whether you have a clear brief or just an idea, let's figure out if we're a good fit."
  canonicalURL={`${SITE.url}/contact`}
>
  <Header />
  <main id="main-content" role="main">
    <section class="max-w-2xl mx-auto px-4 py-20">
      <ScrollReveal client:idle>
        <h1 class="text-5xl font-bold text-gray-900 mb-4">Ready to build something?</h1>
      </ScrollReveal>
      <ScrollReveal client:idle delay={0.2}>
        <p class="text-xl text-gray-600 mb-8">
          Whether you have a clear brief or just an idea, let's figure out if we're a good fit.
        </p>
      </ScrollReveal>

      <ScrollReveal client:idle delay={0.3}>
        <div class="mb-12 p-6 bg-gray-50 rounded-lg text-center">
          <Icon name="tabler:mail" class="w-6 h-6 mx-auto mb-2 text-gray-900" aria-hidden="true" />
          <a
            href="mailto:shaheer@cognitidata.com"
            class="text-lg font-semibold text-gray-900 hover:text-gray-600 transition-colors"
          >
            shaheer@cognitidata.com
          </a>
        </div>
      </ScrollReveal>

      <ScrollReveal client:idle delay={0.4}>
        <ContactForm />
      </ScrollReveal>
    </section>
  </main>
  <Footer />
</Layout>
