---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ScrollReveal.tsx";
import { Icon } from "astro-icon/components";
import { SITE } from "../config/site.mjs";
---

<Layout
  title={`Portfolio | ${SITE.title}`}
  description="See our work — from agentic research platforms to lead generation automation."
  canonicalURL={`${SITE.url}/portfolio`}
>
  <Header />
  <main id="main-content" role="main">
    <section class="max-w-6xl mx-auto px-4 py-20">
      <ScrollReveal client:idle>
        <h1 class="text-5xl font-bold text-gray-900 mb-4">Portfolio</h1>
      </ScrollReveal>
      <ScrollReveal client:load delay={0.1}>
        <p class="text-xl text-gray-600 mb-12">
          See our work — from agentic research platforms to lead generation automation.
        </p>
      </ScrollReveal>

      <div class="grid md:grid-cols-2 gap-8">
        <ScrollReveal client:idle delay={0.2} scale={true}>
          <div class="p-6 bg-white rounded-lg border border-gray-200 hover:shadow-lg transition-shadow h-full flex flex-col">
            <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center mb-4">
              <Icon name="tabler:message-chatbot" class="w-6 h-6 text-gray-900" aria-hidden="true" />
            </div>
            <h2 class="text-2xl font-semibold text-gray-900 mb-3">Digital Twin — Personal AI Assistant</h2>
            <p class="text-gray-600 mb-4 flex-grow">
              A RAG-powered chatbot with long-term memory, user authentication, and streaming responses. Deployed on AWS with a custom domain, Supabase for persistence, and full observability via Langfuse.
            </p>
            <a
              href="https://chat.shaheerairaj.com"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-gray-900 hover:text-gray-600 transition-colors font-medium"
            >
              <Icon name="tabler:external-link" class="w-5 h-5" aria-hidden="true" />
              <span>Live at chat.shaheerairaj.com</span>
            </a>
          </div>
        </ScrollReveal>

        <ScrollReveal client:idle delay={0.3} scale={true}>
          <div class="p-6 bg-white rounded-lg border border-gray-200 hover:shadow-lg transition-shadow h-full flex flex-col">
            <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center mb-4">
              <Icon name="tabler:search" class="w-6 h-6 text-gray-900" aria-hidden="true" />
            </div>
            <h2 class="text-2xl font-semibold text-gray-900 mb-3">ScholarAI — Agentic Research Platform</h2>
            <p class="text-gray-600 mb-4 flex-grow">
              A multi-agent AI system that takes a research query and autonomously breaks it down, searches the web in parallel, evaluates quality, and synthesizes a structured report — all without human intervention.
            </p>
            <a
              href="https://scholarai-web.fly.dev"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-gray-900 hover:text-gray-600 transition-colors font-medium"
            >
              <Icon name="tabler:external-link" class="w-5 h-5" aria-hidden="true" />
              <span>Live at scholarai-web.fly.dev</span>
            </a>
          </div>
        </ScrollReveal>

        <ScrollReveal client:idle delay={0.4} scale={true}>
          <div class="p-6 bg-white rounded-lg border border-gray-200 hover:shadow-lg transition-shadow h-full flex flex-col">
            <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center mb-4">
              <Icon name="tabler:plane" class="w-6 h-6 text-gray-900" aria-hidden="true" />
            </div>
            <h2 class="text-2xl font-semibold text-gray-900 mb-3">Atlas — AI Travel Planner</h2>
            <p class="text-gray-600 mb-4 flex-grow">
              An AI workflow that takes your vacation details and generates a complete day-by-day itinerary including flights, hotels, and tourist highlights.
            </p>
            <a
              href="https://huggingface.co/spaces"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-gray-900 hover:text-gray-600 transition-colors font-medium"
            >
              <Icon name="tabler:external-link" class="w-5 h-5" aria-hidden="true" />
              <span>Live on Hugging Face Spaces</span>
            </a>
          </div>
        </ScrollReveal>

        <ScrollReveal client:idle delay={0.5} scale={true}>
          <div class="p-6 bg-white rounded-lg border border-gray-200 hover:shadow-lg transition-shadow h-full flex flex-col">
            <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center mb-4">
              <Icon name="tabler:mail-forward" class="w-6 h-6 text-gray-900" aria-hidden="true" />
            </div>
            <h2 class="text-2xl font-semibold text-gray-900 mb-3">Lead Generation Automation</h2>
            <p class="text-gray-600 mb-4 flex-grow">
              Built a full outbound sales automation in n8n for a Dubai marketing agency — ICP intake, Apollo.io lead sourcing, enrichment, personalized email generation, and campaign scheduling via Instantly. End-to-end, no manual work.
            </p>
            <span class="inline-flex items-center gap-2 text-gray-500 font-medium">
              <Icon name="tabler:lock" class="w-5 h-5" aria-hidden="true" />
              <span>Private client project</span>
            </span>
          </div>
        </ScrollReveal>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
