---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CTA from "../components/CTA.astro";
import ScrollReveal from "../components/ScrollReveal.tsx";
import { SITE } from "../config/site.mjs";

const projects = [
  {
    num: "01",
    title: "Digital Twin, Personal AI Assistant",
    description: "A RAG-powered chatbot with long-term memory, user authentication, and streaming responses. Deployed on AWS with a custom domain, Supabase for persistence, and full observability via Langfuse.",
    link: "https://chat.shaheerairaj.com",
    linkText: "chat.shaheerairaj.com",
  },
  {
    num: "02",
    title: "ScholarAI, Agentic Research Platform",
    description: "A multi-agent AI system that takes a research query and autonomously breaks it down, searches the web in parallel, evaluates quality, and synthesizes a structured report.",
    link: "https://scholarai-web.fly.dev",
    linkText: "scholarai-web.fly.dev",
  },
  {
    num: "03",
    title: "Atlas, AI Travel Planner",
    description: "An AI workflow that takes your vacation details and generates a complete day-by-day itinerary including flights, hotels, and tourist highlights.",
    link: "https://huggingface.co/spaces",
    linkText: "Hugging Face Spaces",
  },
  {
    num: "04",
    title: "Lead Generation Automation",
    description: "Full outbound sales automation. ICP intake, Apollo.io lead sourcing, enrichment, personalized email generation, and campaign scheduling via Instantly. End-to-end, no manual work.",
    linkText: "Private client project",
  },
];
---

<Layout
  title={`Work | ${SITE.title}`}
  description="Problems solved, time reclaimed. See the AI systems we've built for agencies and SMEs."
  canonicalURL={`${SITE.url}/portfolio`}
>
  <Header />
  <main id="main-content" role="main">
    <section class="px-6" style="padding-top: 96px; padding-bottom: 96px;">
      <div class="mx-auto" style="max-width: 1080px;">
        <ScrollReveal client:idle>
          <p class="eyebrow mb-5">Our work</p>
          <h1
            style="font-size: clamp(44px, 5.5vw, 72px); line-height: 1.1; color: var(--color-text); max-width: 640px;"
          >
            Problems solved, time reclaimed
          </h1>
        </ScrollReveal>

        <div
          class="mt-16"
          style="border-top: 1px solid var(--color-border);"
        >
          {projects.map((project, i) => (
            <ScrollReveal client:idle delay={i * 0.1}>
              <div
                class="grid md:grid-cols-12 gap-8 py-10"
                style={i < projects.length - 1 ? 'border-bottom: 1px solid var(--color-border);' : ''}
              >
                <div class="md:col-span-1">
                  <span
                    style="font-family: 'Montserrat', sans-serif; font-weight: 600; font-size: 44px; color: var(--color-accent-soft);"
                  >
                    {project.num}
                  </span>
                </div>
                <div class="md:col-span-4">
                  <h2
                    style="font-family: 'Montserrat', sans-serif; font-weight: 600; font-size: 32px; color: var(--color-text); line-height: 1.3;"
                  >
                    {project.title}
                  </h2>
                </div>
                <div class="md:col-span-5">
                  <p style="font-size: 19px; color: var(--color-body);">
                    {project.description}
                  </p>
                </div>
                <div class="md:col-span-2 md:text-right">
                  {project.link ? (
                    <a
                      href={project.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="transition-opacity duration-200 hover:opacity-60"
                      style="font-size: 15px; color: var(--color-muted);"
                    >
                      {project.linkText} &rarr;
                    </a>
                  ) : (
                    <span style="font-size: 15px; color: var(--color-hint);">
                      {project.linkText}
                    </span>
                  )}
                </div>
              </div>
            </ScrollReveal>
          ))}
        </div>
      </div>
    </section>
    <CTA />
  </main>
  <Footer />
</Layout>
