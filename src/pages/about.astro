---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhyCognitidata from "../components/WhyCognitidata.astro";
import Founders from "../components/Founders.astro";
import HowWeWork from "../components/HowWeWork.astro";
import CTA from "../components/CTA.astro";
import ScrollReveal from "../components/ScrollReveal.tsx";
import { SITE } from "../config/site.mjs";
---

<Layout
  title={`About | ${SITE.title}`}
  description="We're not an agency. We're the people who build what agencies promise. Dubai-based AI automation for businesses that move fast."
  canonicalURL={`${SITE.url}/about`}
>
  <Header />
  <main id="main-content" role="main">
    <section class="px-6" style="padding-top: 96px; padding-bottom: 48px;">
      <div class="mx-auto" style="max-width: 1080px;">
        <ScrollReveal client:idle>
          <p class="eyebrow mb-5">About</p>
          <h1
            style="font-size: clamp(44px, 5.5vw, 72px); line-height: 1.1; color: var(--color-text); max-width: 640px;"
          >
            We build the systems that let your business run itself
          </h1>
        </ScrollReveal>

        <ScrollReveal client:idle delay={0.1}>
          <div class="grid md:grid-cols-2 gap-16 mt-12">
            <p style="font-size: 22px; line-height: 1.65; color: var(--color-body);">
              Cognitidata is a Dubai-based AI automation consultancy. We design and deploy custom systems for agencies and SMEs, from lead generation to client reporting to internal workflows.
            </p>
            <p style="font-size: 22px; line-height: 1.65; color: var(--color-body);">
              Founded by Shaheer Ahmed, an AI engineer with experience across energy, education, and enterprise sectors. Featured on Dubai One TV, AWS certified, and currently mentoring developers through SuperDataScience.
            </p>
          </div>
        </ScrollReveal>
      </div>
    </section>

    <Founders />
    <WhyCognitidata />
    <HowWeWork />
    <CTA />
  </main>
  <Footer />
</Layout>
