---
import ScrollReveal from "./ScrollReveal.tsx";
---

<section class="px-6" style="padding-top: 96px; padding-bottom: 96px; border-top: 1px solid var(--color-border);" aria-labelledby="featured-heading">
  <div class="mx-auto" style="max-width: 1080px;">
    <div class="grid md:grid-cols-2 gap-16 md:gap-24 items-end">
      <div>
        <ScrollReveal client:idle>
          <p class="eyebrow mb-5">In the media</p>
          <h2
            id="featured-heading"
            style="font-size: clamp(40px, 5vw, 64px); line-height: 1.1; color: var(--color-text);"
          >
            Featured on Dubai One TV
          </h2>
        </ScrollReveal>
      </div>

      <div class="flex flex-col justify-end">
        <ScrollReveal client:idle delay={0.1}>
          <p style="font-size: 22px; line-height: 1.65; color: var(--color-body);">
            Shaheer joined DXB Today on Dubai One TV to talk about how businesses across the UAE can put AI to work — practically, and today.
          </p>
        </ScrollReveal>
      </div>
    </div>

    <ScrollReveal client:idle delay={0.15}>
      <figure class="mt-16">
        <div style="border: 1px solid var(--color-border); border-radius: 8px; overflow: hidden; background-color: var(--color-surface);">
          <img
            src="/dubai-one-tv.jpg"
            alt="Shaheer Airaj Ahmed featured on Dubai One TV's DXB Today"
            width="1820"
            height="932"
            loading="lazy"
            style="width: 100%; height: auto; display: block;"
          />
        </div>
        <figcaption class="mt-4" style="font-size: 15px; color: var(--color-muted);">
          Shaheer on Dubai One TV &mdash; DXB Today
        </figcaption>
      </figure>
    </ScrollReveal>
  </div>
</section>
