---
import ScrollReveal from "./ScrollReveal.tsx";

const principles = [
  {
    num: "01",
    title: "Production-grade, not demo-grade",
    body: "Every system we build runs in a real business environment. We don\u2019t do proofs of concept that collect dust.",
  },
  {
    num: "02",
    title: "No black boxes",
    body: "You\u2019ll know exactly how your system works. We document everything and train your team before we close out.",
  },
  {
    num: "03",
    title: "No lock-in, ever",
    body: "All code, all workflows, all documentation. Yours. You\u2019re never dependent on us to keep things running.",
  },
];
---

<section class="px-6" style="padding-top: 96px; padding-bottom: 96px;" aria-labelledby="how-we-work-heading">
  <div class="mx-auto" style="max-width: 1080px;">
    <ScrollReveal client:idle>
      <p class="eyebrow mb-5">How we work</p>
      <h2
        id="how-we-work-heading"
        style="font-size: clamp(44px, 5.5vw, 72px); line-height: 1.1; color: var(--color-text); max-width: 640px;"
      >
        Built for your business. Owned by you.
      </h2>
    </ScrollReveal>

    <div
      class="grid md:grid-cols-3 mt-16"
      style="border-top: 1px solid var(--color-border);"
    >
      {principles.map((item, i) => (
        <ScrollReveal client:idle delay={i * 0.1}>
          <div
            class="pt-8 pb-8"
            style={`${i > 0 ? 'border-left: 1px solid var(--color-border); padding-left: 2rem;' : 'padding-right: 2rem;'}`}
          >
            <span
              style="font-family: 'Cormorant Garamond', serif; font-weight: 500; font-size: 44px; color: var(--color-muted);"
            >
              {item.num}
            </span>
            <h3
              class="mt-4"
              style="font-family: 'Cormorant Garamond', serif; font-weight: 500; font-size: 30px; color: var(--color-text); line-height: 1.3;"
            >
              {item.title}
            </h3>
            <p class="mt-3" style="font-size: 19px; color: var(--color-body);">
              {item.body}
            </p>
          </div>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>
