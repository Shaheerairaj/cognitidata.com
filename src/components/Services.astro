---
import ScrollReveal from "./ScrollReveal.tsx";

const services = [
  {
    num: "01",
    title: "More leads, less effort",
    items: "Cold Email Systems \u00b7 Outbound Pipelines \u00b7 Lead Qualification",
  },
  {
    num: "02",
    title: "Close deals faster",
    items: "Proposal Automation \u00b7 Follow-up Sequences \u00b7 Payment Collection",
  },
  {
    num: "03",
    title: "Keep clients longer",
    items: "Reporting Automation \u00b7 Client Dashboards \u00b7 Renewal Triggers",
  },
  {
    num: "04",
    title: "Reclaim your team\u2019s time",
    items: "Workflow Automation \u00b7 Data Entry Removal \u00b7 Internal Bots",
  },
  {
    num: "05",
    title: "Know your numbers without asking",
    items: "CRM Integration \u00b7 Live Dashboards \u00b7 Automated Reports",
  },
  {
    num: "06",
    title: "Build once, run forever",
    items: "Custom AI Agents \u00b7 WhatsApp Bots \u00b7 System Integration",
  },
];
---

<section id="services" class="px-6" style="padding-top: 96px; padding-bottom: 96px;" aria-labelledby="services-heading">
  <div class="mx-auto" style="max-width: 1080px;">
    <ScrollReveal client:idle>
      <p class="eyebrow mb-5">What we do</p>
      <h2
        id="services-heading"
        style="font-size: clamp(44px, 5.5vw, 72px); line-height: 1.1; color: var(--color-text); max-width: 640px;"
      >
        The work that slows you down, automated
      </h2>
    </ScrollReveal>

    <div
      class="grid md:grid-cols-3 mt-16"
      style="border-top: 1px solid var(--color-border);"
    >
      {services.map((service, i) => (
        <ScrollReveal client:idle delay={i * 0.08}>
          <div
            class={`pt-8 pb-10 ${i >= 3 ? '' : ''}`}
            style={`
              ${(i % 3 !== 0) ? 'border-left: 1px solid var(--color-border); padding-left: 2rem;' : ''}
              ${(i % 3 !== 2) ? 'padding-right: 2rem;' : ''}
              ${i < 3 ? 'border-bottom: 1px solid var(--color-border);' : ''}
            `}
          >
            <span
              style="font-family: 'Cormorant Garamond', serif; font-weight: 500; font-size: 44px; color: var(--color-muted);"
            >
              {service.num}
            </span>
            <h3
              class="mt-4"
              style="font-family: 'Cormorant Garamond', serif; font-weight: 500; font-size: 30px; color: var(--color-text); line-height: 1.3;"
            >
              {service.title}
            </h3>
            <p class="mt-3" style="font-size: 17px; color: var(--color-muted); line-height: 1.7;">
              {service.items}
            </p>
          </div>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>
