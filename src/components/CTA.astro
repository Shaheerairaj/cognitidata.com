---
import ScrollReveal from "./ScrollReveal.tsx";
---

<section class="px-6" style="padding-top: 96px; padding-bottom: 96px;" aria-labelledby="cta-heading">
  <div class="mx-auto" style="max-width: 640px;">
    <ScrollReveal client:idle>
      <h2
        id="cta-heading"
        style="font-size: clamp(44px, 5.5vw, 72px); line-height: 1.1; color: var(--color-text);"
      >
        Something in your business taking too long?
      </h2>
    </ScrollReveal>

    <ScrollReveal client:idle delay={0.1}>
      <p class="mt-6" style="font-size: 22px; line-height: 1.65; color: var(--color-body); max-width: 480px;">
        Let's find it and fix it. First call is free, no pitch deck, no pressure.
      </p>
    </ScrollReveal>

    <ScrollReveal client:idle delay={0.2}>
      <div class="flex items-center gap-8 mt-10">
        <a href="/contact" class="btn-primary">Book a discovery call</a>
        <a href="#process" class="btn-ghost">See how we work &rarr;</a>
      </div>
    </ScrollReveal>
  </div>
</section>
