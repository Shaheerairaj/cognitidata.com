---
import ScrollReveal from "./ScrollReveal.tsx";

const sessions = [
  {
    num: "01",
    title: "Set up",
    body: "Pick one painful task and set up Claude around it — projects scoped to your function, best practices taught while we build.",
  },
  {
    num: "02",
    title: "Build",
    body: "We build your first workflow live together using Skills, so the knowledge stays with your team.",
  },
  {
    num: "03",
    title: "Hand off",
    body: "Triggers and scheduling with Cowork, then test, debug, and hand over with full documentation.",
  },
];
---

<section class="px-6" style="padding-top: 96px; padding-bottom: 96px; border-top: 1px solid var(--color-border);" aria-labelledby="workshop-teaser-heading">
  <div class="mx-auto" style="max-width: 1080px;">
    <div class="grid md:grid-cols-2 gap-16 md:gap-24">
      <div>
        <ScrollReveal client:idle>
          <p class="eyebrow mb-5">Done with you</p>
          <h2
            id="workshop-teaser-heading"
            style="font-size: clamp(44px, 5.5vw, 72px); line-height: 1.1; color: var(--color-text);"
          >
            Deliver <em style="font-style: italic; font-weight: 400;">3x faster</em> in 21 days
          </h2>
        </ScrollReveal>
      </div>

      <div class="flex flex-col justify-center">
        <ScrollReveal client:idle delay={0.1}>
          <p style="font-size: 22px; line-height: 1.65; color: var(--color-body);">
            The AI Adoption Workshop is a guided, three-week program. We migrate your team to Claude, personalize it to how your business actually works, and build one real workflow live — so faster delivery outlasts the workshop.
          </p>
        </ScrollReveal>
      </div>
    </div>

    <div class="grid md:grid-cols-3 mt-16" style="border-top: 1px solid var(--color-border);">
      {sessions.map((session, i) => (
        <ScrollReveal client:idle delay={i * 0.1}>
          <div
            class="pt-8 pb-8"
            style={`${i > 0 ? 'border-left: 1px solid var(--color-border); padding-left: 2rem;' : 'padding-right: 2rem;'}`}
          >
            <span
              style="font-family: 'Cormorant Garamond', serif; font-weight: 500; font-size: 44px; color: var(--color-muted);"
            >
              {session.num}
            </span>
            <h3
              class="mt-4"
              style="font-family: 'Cormorant Garamond', serif; font-weight: 500; font-size: 28px; color: var(--color-text); line-height: 1.3;"
            >
              {session.title}
            </h3>
            <p class="mt-3" style="font-size: 18px; color: var(--color-body); line-height: 1.7;">
              {session.body}
            </p>
          </div>
        </ScrollReveal>
      ))}
    </div>

    <ScrollReveal client:idle delay={0.2}>
      <div class="mt-12">
        <a href="/workshop" class="btn-primary">See the full workshop</a>
      </div>
    </ScrollReveal>
  </div>
</section>
