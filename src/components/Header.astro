---
const currentPath = Astro.url.pathname;
---

<header
  class="w-full border-b"
  style="height: 64px; border-color: var(--color-border);"
  role="banner"
>
  <nav
    class="mx-auto flex items-center justify-between h-full px-6"
    style="max-width: 1080px;"
    aria-label="Main navigation"
  >
    <a
      href="/"
      class="transition-opacity duration-200 hover:opacity-60"
      aria-label="Cognitidata - Home"
    >
      <img
        src="/interrupted-black.svg"
        alt="Cognitidata"
        width="320"
        height="64"
        style="height: 64px; width: auto;"
      />
    </a>

    <!-- Mobile menu button -->
    <button
      type="button"
      class="md:hidden p-2 focus:outline-none"
      style="color: var(--color-muted);"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      id="mobile-menu-button"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="3" y1="5" x2="17" y2="5" />
        <line x1="3" y1="10" x2="17" y2="10" />
        <line x1="3" y1="15" x2="17" y2="15" />
      </svg>
    </button>

    <!-- Desktop navigation -->
    <div class="hidden md:flex items-center gap-10">
      <ul class="flex items-center gap-8" role="list">
        <li>
          <a
            href="/services"
            class="transition-opacity duration-200 hover:opacity-60"
            style={`font-family: 'Outfit', sans-serif; font-weight: 500; font-size: 16px; color: ${currentPath === '/services' ? 'var(--color-text)' : 'var(--color-muted)'};`}
            aria-current={currentPath === '/services' ? 'page' : undefined}
          >
            Services
          </a>
        </li>
        <li>
          <a
            href="/portfolio"
            class="transition-opacity duration-200 hover:opacity-60"
            style={`font-family: 'Outfit', sans-serif; font-weight: 500; font-size: 16px; color: ${currentPath === '/portfolio' ? 'var(--color-text)' : 'var(--color-muted)'};`}
            aria-current={currentPath === '/portfolio' ? 'page' : undefined}
          >
            Work
          </a>
        </li>
        <li>
          <a
            href="/about"
            class="transition-opacity duration-200 hover:opacity-60"
            style={`font-family: 'Outfit', sans-serif; font-weight: 500; font-size: 16px; color: ${currentPath === '/about' ? 'var(--color-text)' : 'var(--color-muted)'};`}
            aria-current={currentPath === '/about' ? 'page' : undefined}
          >
            About
          </a>
        </li>
        <li>
          <a
            href="/contact"
            class="transition-opacity duration-200 hover:opacity-60"
            style={`font-family: 'Outfit', sans-serif; font-weight: 500; font-size: 16px; color: ${currentPath === '/contact' ? 'var(--color-text)' : 'var(--color-muted)'};`}
            aria-current={currentPath === '/contact' ? 'page' : undefined}
          >
            Contact
          </a>
        </li>
      </ul>
      <a href="/contact" class="btn-primary">
        Book a call
      </a>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t"
    style="border-color: var(--color-border); background-color: var(--color-bg);"
    role="menu"
    aria-labelledby="mobile-menu-button"
  >
    <ul class="flex flex-col py-4 px-6" role="list">
      <li>
        <a
          href="/services"
          class="block py-3 transition-opacity duration-200 hover:opacity-60"
          style={`font-family: 'Outfit', sans-serif; font-weight: 500; font-size: 16px; color: ${currentPath === '/services' ? 'var(--color-text)' : 'var(--color-muted)'};`}
          role="menuitem"
          aria-current={currentPath === '/services' ? 'page' : undefined}
        >
          Services
        </a>
      </li>
      <li>
        <a
          href="/portfolio"
          class="block py-3 transition-opacity duration-200 hover:opacity-60"
          style={`font-family: 'Outfit', sans-serif; font-weight: 500; font-size: 16px; color: ${currentPath === '/portfolio' ? 'var(--color-text)' : 'var(--color-muted)'};`}
          role="menuitem"
          aria-current={currentPath === '/portfolio' ? 'page' : undefined}
        >
          Work
        </a>
      </li>
      <li>
        <a
          href="/about"
          class="block py-3 transition-opacity duration-200 hover:opacity-60"
          style={`font-family: 'Outfit', sans-serif; font-weight: 500; font-size: 16px; color: ${currentPath === '/about' ? 'var(--color-text)' : 'var(--color-muted)'};`}
          role="menuitem"
          aria-current={currentPath === '/about' ? 'page' : undefined}
        >
          About
        </a>
      </li>
      <li>
        <a
          href="/contact"
          class="block py-3 transition-opacity duration-200 hover:opacity-60"
          style={`font-family: 'Outfit', sans-serif; font-weight: 500; font-size: 16px; color: ${currentPath === '/contact' ? 'var(--color-text)' : 'var(--color-muted)'};`}
          role="menuitem"
          aria-current={currentPath === '/contact' ? 'page' : undefined}
        >
          Contact
        </a>
      </li>
      <li class="pt-4">
        <a href="/contact" class="btn-primary">
          Book a call
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const menuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');

  if (menuButton && mobileMenu) {
    menuButton.addEventListener('click', () => {
      const isExpanded = menuButton.getAttribute('aria-expanded') === 'true';
      menuButton.setAttribute('aria-expanded', String(!isExpanded));
      mobileMenu.classList.toggle('hidden');
    });

    document.addEventListener('click', (e) => {
      if (
        !menuButton.contains(e.target as Node) &&
        !mobileMenu.contains(e.target as Node) &&
        !mobileMenu.classList.contains('hidden')
      ) {
        menuButton.setAttribute('aria-expanded', 'false');
        mobileMenu.classList.add('hidden');
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !mobileMenu.classList.contains('hidden')) {
        menuButton.setAttribute('aria-expanded', 'false');
        mobileMenu.classList.add('hidden');
        menuButton.focus();
      }
    });
  }
</script>
