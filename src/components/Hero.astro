---
import ScrollReveal from "./ScrollReveal.tsx";
---

<section class="px-6" style="padding-top: 96px; padding-bottom: 96px;" aria-labelledby="hero-heading">
  <div class="mx-auto" style="max-width: 1080px;">
    <ScrollReveal client:load>
      <p class="eyebrow mb-6">AI Automation &amp; Adoption &middot; Dubai, UAE</p>
    </ScrollReveal>

    <ScrollReveal client:load delay={0.1}>
      <h1
        id="hero-heading"
        style="font-size: clamp(60px, 8vw, 88px); line-height: 1.05; letter-spacing: -0.01em; color: var(--color-text);"
      >
        Your business,<br />running <em style="font-style: italic; font-weight: 400;">faster</em>
      </h1>
    </ScrollReveal>

    <ScrollReveal client:load delay={0.2}>
      <p
        class="mt-8"
        style="max-width: 600px; font-size: 22px; line-height: 1.65; color: var(--color-body);"
      >
        We help agencies and SMEs across the UAE move faster with AI — two ways. We build custom automation that does the repetitive work for you. Or we implement Claude alongside your team, so you deliver 3x faster.
      </p>
    </ScrollReveal>

    <ScrollReveal client:load delay={0.3}>
      <div class="flex items-center gap-8 mt-10">
        <a href="#two-ways" class="btn-primary">Two ways to work with us</a>
        <a href="/workshop" class="btn-ghost">The Claude workshop &rarr;</a>
      </div>
    </ScrollReveal>
  </div>
</section>
