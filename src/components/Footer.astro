---
const year = new Date().getFullYear();
---

<footer
  class="w-full px-6 border-t"
  style="border-color: var(--color-border); padding-top: 64px; padding-bottom: 48px;"
  role="contentinfo"
>
  <div class="mx-auto" style="max-width: 1080px;">
    <div class="grid md:grid-cols-4 gap-12 md:gap-8">
      <!-- Brand -->
      <div>
        <a href="/" class="inline-block">
          <img
            src="/interrupted-black.svg"
            alt="Cognitidata"
            width="320"
            height="64"
            style="height: 64px; width: auto;"
          />
        </a>
        <p class="mt-4" style="font-size: 15px; color: var(--color-muted); line-height: 1.7;">
          AI automation for businesses that move fast.
        </p>
      </div>

      <!-- Company -->
      <div>
        <p class="eyebrow mb-4">Company</p>
        <ul class="space-y-3">
          <li>
            <a
              href="/about"
              class="transition-opacity duration-200 hover:opacity-60"
              style="font-size: 16px; color: var(--color-body);"
            >
              About
            </a>
          </li>
          <li>
            <a
              href="/portfolio"
              class="transition-opacity duration-200 hover:opacity-60"
              style="font-size: 16px; color: var(--color-body);"
            >
              Work
            </a>
          </li>
          <li>
            <a
              href="/contact"
              class="transition-opacity duration-200 hover:opacity-60"
              style="font-size: 16px; color: var(--color-body);"
            >
              Contact
            </a>
          </li>
        </ul>
      </div>

      <!-- Services -->
      <div>
        <p class="eyebrow mb-4">Services</p>
        <ul class="space-y-3">
          <li>
            <a
              href="/services"
              class="transition-opacity duration-200 hover:opacity-60"
              style="font-size: 16px; color: var(--color-body);"
            >
              Workflow Automation
            </a>
          </li>
          <li>
            <a
              href="/services"
              class="transition-opacity duration-200 hover:opacity-60"
              style="font-size: 16px; color: var(--color-body);"
            >
              Sales Automation
            </a>
          </li>
          <li>
            <a
              href="/services"
              class="transition-opacity duration-200 hover:opacity-60"
              style="font-size: 16px; color: var(--color-body);"
            >
              AI Agents
            </a>
          </li>
          <li>
            <a
              href="/services"
              class="transition-opacity duration-200 hover:opacity-60"
              style="font-size: 16px; color: var(--color-body);"
            >
              System Integration
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="eyebrow mb-4">Contact</p>
        <ul class="space-y-3">
          <li>
            <a
              href="mailto:shaheer@cognitidata.com"
              class="transition-opacity duration-200 hover:opacity-60"
              style="font-size: 16px; color: var(--color-body);"
            >
              shaheer@cognitidata.com
            </a>
          </li>
          <li>
            <span style="font-size: 16px; color: var(--color-body);">
              cognitidata.com
            </span>
          </li>
          <li>
            <span style="font-size: 16px; color: var(--color-body);">
              Dubai, UAE
            </span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="mt-16 pt-6 border-t flex flex-col sm:flex-row sm:justify-between gap-2"
      style="border-color: var(--color-border);"
    >
      <p style="font-size: 14px; color: var(--color-hint);">
        &copy; {year} Cognitidata AI Solutions &middot; All rights reserved
      </p>
    </div>
  </div>
</footer>
